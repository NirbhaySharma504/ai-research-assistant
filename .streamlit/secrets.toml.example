# Copy to .streamlit/secrets.toml (gitignored) or set in the Streamlit Cloud
# dashboard. Point this at your backend. For a public Streamlit Cloud deployment the
# backend must be reachable from the internet — expose your local backend with a
# tunnel, e.g.  cloudflared tunnel --url http://localhost:8000  (or ngrok).
BACKEND_URL = "https://your-backend-tunnel.example.com"
