# --- LLM provider: "ollama" (local) or "groq" (hosted) ---
LLM_PROVIDER=ollama

# --- Ollama (local) ---
# On a CUDA GPU (e.g. RTX 2060 Super, 8GB VRAM) use llama3.1:8b.
# On a low-RAM/CPU machine fall back to llama3.2:3b.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Groq (hosted, OpenAI-compatible; used for swap + RAGAS judge) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# RAGAS judge model. 8b-instant has a much larger free-tier daily token limit, so
# evaluation won't exhaust the 70b quota. Use GROQ_MODEL for a stronger judge.
GROQ_JUDGE_MODEL=llama-3.1-8b-instant

# --- OpenRouter (preferred RAGAS judge; pay-per-use, reliable structured output) ---
# Takes priority over Groq for evaluation. gpt-4o-mini scores all 3 RAGAS metrics
# reliably (the small Groq models NaN context precision). Full benchmark costs ~$0.20.
OPENROUTER_API_KEY=
OPENROUTER_JUDGE_MODEL=openai/gpt-4o-mini

# --- Web search ---
TAVILY_API_KEY=tvly-xxxxxxxxxxxxx

# --- Observability (optional): LangSmith tracing for every agent/LLM call ---
# Set to true and add a key from https://smith.langchain.com to see full traces.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-research-assistant

# --- Storage ---
CHROMA_DB_PATH=./chroma_db
SQLITE_DB_PATH=./research.db

# --- Tunables ---
MAX_SCRAPE_TIMEOUT=10
MAX_RESULTS_PER_SEARCH=5
CHUNK_SIZE=512
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=8           # chunks fed to the synthesizer (fewer = higher precision)
CONTEXT_MAX_DISTANCE=0.70   # cosine-distance ceiling for a chunk to count as relevant
MIN_CONTEXT_CHUNKS=5        # floor so the synthesizer is never starved
LOG_LEVEL=INFO
